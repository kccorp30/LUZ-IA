{
  "name": "luz-ia",
  "version": "2.0.0",
  "description": "LUZ IA - Sistema de gestión para restaurantes con IA",
  "main": "index.js",
  "scripts": {
    "build:css": "tailwindcss -i ./src/input.css -o ./dist/output.css --minify",
    "watch:css": "tailwindcss -i ./src/input.css -o ./dist/output.css --watch",
    "dev": "node index.js",
    "start": "node index.js",
    "postinstall": "npm run build:css"
  },
  "dependencies": {
    "axios": "^1.6.0",
    "express": "^4.18.0",
    "form-data": "^4.0.0",
    "web-push": "^3.6.0"
  },
  "devDependencies": {
    "tailwindcss": "^3.4.0",
    "@tailwindcss/forms": "^0.5.7",
    "@tailwindcss/typography": "^0.5.10"
  },
  "engines": {
    "node": ">=18.0.0"
  }
}
